{
  "name": "ngx-vs-2csv",
  "version": "0.4.0",
  "description": "Angular2 module for saving CSV files.",
  "main": "Ng2Csv.bundle.js",
  "module": "index.js",
  "jsnext:main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "rm -rf dist && npm run lint && tsc -p tsconfig-esm.json && rollup -c rollup.config.js dist/index.js > dist/Ng2Csv.bundle.js && cp package.json dist && ngc && cp README.md dist && cp LICENSE.md dist",
    "test": "karma start --single-run",
    "lint": "tslint -c tslint.json 'src/**/*.ts' 'test/**/*.ts'",
    "release": "standard-version",
    "npmpublish": "cd dist && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rars/ng2csv"
  },
  "keywords": [
    "Angular2",
    "ng2",
    "CSV"
  ],
  "author": "Richard Russell",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rars/ng2csv/issues"
  },
  "homepage": "https://github.com/rars/ng2csv#readme",
  "peerDependencies": {
    "file-saver": "^1.3.3"
  },
  "devDependencies": {
    "@angular/common": "^11.2.4",
    "@angular/compiler": "^11.2.4",
    "@angular/compiler-cli": "^11.2.4",
    "@angular/core": "^11.2.4",
    "@angular/platform-browser": "^11.2.4",
    "@angular/platform-browser-dynamic": "^11.2.4",
    "@angular/platform-server": "^11.2.4",
    "@types/file-saver": "0.0.1",
    "@types/jasmine": "^2.8.17",
    "@types/jsdom": "^11.12.0",
    "@types/node": "^8.10.66",
    "core-js": "^2.6.12",
    "cz-conventional-changelog": "^2.1.0",
    "file-saver": "^1.3.8",
    "jasmine": "^2.99.0",
    "jasmine-core": "^2.99.1",
    "jsdom": "^9.12.0",
    "karma": "^1.7.1",
    "karma-chrome-launcher": "^2.2.0",
    "karma-firefox-launcher": "^1.3.0",
    "karma-jasmine": "^1.1.2",
    "karma-jasmine-html-reporter": "^0.2.2",
    "karma-sourcemap-loader": "^0.3.8",
    "karma-webpack": "^2.0.13",
    "rollup": "^0.45.1",
    "rxjs": "^6.6.6",
    "standard-version": "^4.4.0",
    "ts-loader": "^2.3.7",
    "ts-node": "^3.3.0",
    "tslint": "^5.20.1",
    "typescript": "4.0.7",
    "webpack": "^3.12.0",
    "zone.js": "^0.11.4"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
